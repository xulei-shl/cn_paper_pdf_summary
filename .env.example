# Memos Instance Configuration
# Copy this file to .env and fill in your actual values

# Your Memos instance URL (e.g., https://memos.example.com or http://localhost:5230)
MEMOS_BASE_URL=https://your-memos-instance.com
MEMOS_ACCESS_TOKEN=memos_pat_your_token_here

---

# Blinko 配置
BLINKO_BASE_URL=your_blinko_base_url_here
BLINKO_API_KEY=your_blinko_api_key_here

---

# LIS-RSS API 配置
LIS_RSS_API_URL=https://your-lis-rss.com
LIS_RSS_USERNAME=your_username
LIS_RSS_PASSWORD=your_password

---

# HiAgent RAG知识库配置
# 工作空间类型（可选，默认 personal）
WorkspaceType=personal
# 工作空间 ID（必填）
WorkspaceID=your_workspace_id
# 知识库 ID（必填）
DatasetID=your_knowledge_id

# HiAgent PDF总结Agent配置

HIAGENT_PDF_URL = https://your-hiagent-pdf-url.com

---

# 企业微信推送配置
# true: 默认推送；false: 仅在 Telegram /papers 使用 --wechat 时推送
PDF_SUMMARY_PUSH_WECHAT=false
WECHAT_WEBHOOK_KEY=your_wechat_webhook_key_here

---

# Telegram Bot 配置
# 从 @BotFather 获取 Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# 可选：允许访问 Telegram Bot 的用户 ID
TELEGRAM_USER_ID=your_telegram_user_id
# 成功日志是否主动推送到 Telegram
# 仅影响 CLI / API 成功后的主动日志推送，不影响 Telegram Bot /papers 的固定结束日志
PDF_SUMMARY_PUSH_TELEGRAM_LOG=false
# 成功结果正文是否推送到 Telegram
# 影响所有入口（CLI / API / Telegram Bot）的最终摘要正文主动推送
PDF_SUMMARY_PUSH_TELEGRAM_RESULT=false
# API 监听地址（可选，默认 0.0.0.0）
PDF_SUMMARY_API_BIND_HOST=0.0.0.0
# API 监听端口（可选，默认 8081）
PDF_SUMMARY_API_PORT=8081
# API 健康检查地址（仅统一启动脚本使用，默认 127.0.0.1）
PDF_SUMMARY_API_HEALTH_HOST=127.0.0.1
# API 启动超时时间（秒，仅统一启动脚本使用）
PDF_SUMMARY_API_START_TIMEOUT=30

TELEGRAM_API_TIMEOUT=300

# HTTP 代理（可选，用于 Telegram API 访问）
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
